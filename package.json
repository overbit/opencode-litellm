{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@overbit/opencode-plugin-litellm",
  "version": "0.5.4",
  "description": "Fork of opencode-plugin-litellm. OpenCode plugin for LiteLLM proxy support with auto-detection and dynamic model discovery.",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck",
    "prepublishOnly": "npm run build",
    "semantic-release": "semantic-release"
  },
  "keywords": [
    "opencode",
    "litellm",
    "lite-llm",
    "plugin",
    "llm-proxy",
    "openai-compatible"
  ],
  "author": "Yusef Mohamadi (https://github.com/yuseferi)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/overbit/opencode-litellm.git"
  },
  "bugs": {
    "url": "https://github.com/overbit/opencode-litellm/issues"
  },
  "homepage": "https://github.com/overbit/opencode-litellm#readme",
  "dependencies": {
    "@opencode-ai/plugin": "^1.14.0",
    "@opencode-ai/sdk": "^1.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "semantic-release": "^24.2.3",
    "typescript": "^5.9.3"
  }
}
